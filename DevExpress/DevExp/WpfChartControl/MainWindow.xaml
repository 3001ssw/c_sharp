<Window xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
        x:Class="WpfChartControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfChartControl"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="부서별 평균 연봉"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="5"/>
        <dxc:ChartControl Grid.Row="1"
                          DataSource="{Binding SalaryData}">
            <dxc:ChartControl.Titles>
                <dxc:Title Content="부서별 평균 연봉"
                           HorizontalAlignment="Center"/>
            </dxc:ChartControl.Titles>
            <dxc:ChartControl.Legends>
                <dxc:Legend/>
            </dxc:ChartControl.Legends>
            <dxc:XYDiagram2D>
                <dxc:XYDiagram2D.AxisX>
                    <dxc:AxisX2D/>
                </dxc:XYDiagram2D.AxisX>
                <dxc:XYDiagram2D.AxisY>
                    <dxc:AxisY2D/>
                </dxc:XYDiagram2D.AxisY>
                <dxc:BarSideBySideSeries2D ArgumentDataMember="Department"
                                           ValueDataMember="AverageSalary"
                                           DisplayName="평균 연봉"/>
            </dxc:XYDiagram2D>
        </dxc:ChartControl>
    </Grid>
</Window>
