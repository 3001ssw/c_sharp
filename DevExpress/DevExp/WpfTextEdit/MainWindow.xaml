<Window x:Class="WpfTextEdit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfTextEdit"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="600"
        Width="800"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <StackPanel Margin="20"
                Orientation="Vertical">


        <!--  TextEdit  -->
        <TextBlock Text="TextEdit"/>
        <dxe:TextEdit Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                      NullText="이름을 입력하세요"
                      Margin="5"/>

        <!--  MemoEdit  -->
        <TextBlock Text="MemoEdit"/>
        <dxe:MemoEdit Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"
                      NullText="메모를 입력하세요"
                      ShowIcon="False"
                      Margin="5"/>

        <!--  PasswordBoxEdit  -->
        <TextBlock Text="PasswordBoxEdit"/>
        <dxe:PasswordBoxEdit Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             NullText="비밀번호를 입력하세요"
                             Margin="5">

            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand EventName="EditValueChanged"
                                       Command="{Binding PasswordChangedCommand}"
                                       PassEventArgsToCommand="True"/>
            </dxmvvm:Interaction.Behaviors>
        </dxe:PasswordBoxEdit>

        <!--  ButtonEdit  -->
        <TextBlock Text="ButtonEdit"/>
        <dxe:ButtonEdit Text="{Binding ButtonEditText, UpdateSourceTrigger=PropertyChanged}"
                        NullText="버튼을 클릭해보세요"
                        Margin="5">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand EventName="DefaultButtonClick"
                                       Command="{Binding DefaultButtonClickCommand}"/>
            </dxmvvm:Interaction.Behaviors>
            <dxe:ButtonEdit.Buttons>
                <dxe:ButtonInfo Content="클릭"
                                GlyphKind="Apply"
                                Command="{Binding ButtonClickCommand}"/>
                <dxe:ButtonInfo Content="초기화"
                                GlyphKind="None"
                                Command="{Binding ButtonClickInitCommand}"/>
            </dxe:ButtonEdit.Buttons>
        </dxe:ButtonEdit>

        <!--  BrowsePathEdit  -->
        <TextBlock Text="BrowsePathEdit"/>
        <dxe:BrowsePathEdit Text="{Binding BrowsePath, UpdateSourceTrigger=PropertyChanged}"
                            NullText="경로를 선택하세요"
                            Margin="5"/>

        <!--  DateEdit  -->
        <TextBlock Text="DateEdit"/>
        <dxe:DateEdit EditValue="{Binding SelectedDate, UpdateSourceTrigger=PropertyChanged}"
                      NullText="날짜를 선택하세요"
                      Margin="5"/>

        <!--  FontEdit  -->
        <TextBlock Text="FontEdit"/>
        <dxe:FontEdit EditValue="{Binding SelectedFont, UpdateSourceTrigger=PropertyChanged}"
                      NullText="폰트를 선택하세요"
                      Margin="5"/>

        <!--  SpinEdit  -->
        <TextBlock Text="SpinEdit"/>
        <dxe:SpinEdit EditValue="{Binding SpinValue, UpdateSourceTrigger=PropertyChanged}"
                      MinValue="0"
                      MaxValue="100"
                      Increment="1"
                      Margin="5"/>
    </StackPanel>
</Window>
