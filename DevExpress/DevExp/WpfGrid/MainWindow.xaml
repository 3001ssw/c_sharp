<Window xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        x:Class="WpfGrid.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfGrid"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="직원 목록"
                   FontWeight="Bold"
                   FontSize="16"
                   Margin="5"/>

        <dxg:GridControl Grid.Row="1"
                         ItemsSource="{Binding Employees}"
                         SelectedItem="{Binding SelectedEmployee}"
                         AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False"
                               AutoWidth="True"
                               AllowEditing="True"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Id"
                                Header="번호"
                                Width="60"
                                AllowEditing="False"/>
                <dxg:GridColumn FieldName="Name"
                                Header="이름"/>
                <dxg:GridColumn FieldName="Department"
                                Header="부서"/>
                <dxg:GridColumn FieldName="JoinDate"
                                Header="입사일"/>
                <dxg:GridColumn FieldName="Salary"
                                Header="연봉"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="5">
            <Button Content="추가"
                    Command="{Binding AddCommand}"
                    Width="80"
                    Margin="5"/>
            <Button Content="삭제"
                    Command="{Binding DeleteCommand}"
                    Width="80"
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
