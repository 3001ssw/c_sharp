<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfButton"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        x:Class="WpfButton.MainWindow"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <StackPanel Orientation="Vertical">

        <dx:SimpleButton Content="SimpleButton"
                         Margin="5"
                         Command="{Binding SimpleButtonCommand}"/>

        <dx:SplitButton Content="SplitButton"
                        Margin="5"
                        Command="{Binding SplitButtonCommand}">
            <dxb:PopupMenu>
                <dxb:BarButtonItem Content="Menu 1"
                                   Command="{Binding SplitButtonMenu1Command}"/>
                <dxb:BarButtonItem Content="Menu 2"
                                   Command="{Binding SplitButtonMenu2Command}"/>
            </dxb:PopupMenu>
        </dx:SplitButton>

        <dx:DropDownButton Content="DropDownButton"
                           Margin="5">
            <dxb:PopupMenu>
                <dxb:BarButtonItem Content="Menu 1"
                                   Command="{Binding DropDownButtonMenu1Command}"/>
                <dxb:BarButtonItem Content="Menu 2"
                                   Command="{Binding DropDownButtonMenu2Command}"/>
            </dxb:PopupMenu>
        </dx:DropDownButton>

    </StackPanel>
</Window>
