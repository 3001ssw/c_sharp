<Window x:Class="WpfClustering.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClustering"
        mc:Ignorable="d"
        Title="뉴스 클러스터링"
        Height="600"
        Width="1000">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="클러스터링 실행"
                Command="{Binding ClusteringCommand}"
                Padding="12,6"
                Margin="0,0,0,12"
                HorizontalAlignment="Left"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--  좌측: 전체 질문 목록  -->
            <GroupBox Grid.Column="0"
                      Header="전체 질문 목록">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Questions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}"
                                           FontSize="12"
                                           Padding="4,3"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="#DDD"/>

            <!--  우측: 클러스터링 결과  -->
            <GroupBox Grid.Column="2"
                      Header="클러스터링 결과">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding ClusterResults}"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</Window>